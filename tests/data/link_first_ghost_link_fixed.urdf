<?xml version="1.0"?>
<robot name="link_first_ghost_link_fixed">
  <!-- Ghost Link: Links that don't carry any information -->
  <link name="BaseLink" />

  <link name="link1">
    <visual>
      <geometry>
        <box size="1.0 1.0 1.0"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="1.0 1.0 1.0"/>
      </geometry>
    </collision>
  </link>
  <link name="link_box">
    <visual>
      <geometry>
        <box size="0.5 0.5 0.5"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box size="0.5 0.5 0.5"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint1" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 1"/>
    <parent link="BaseLink"/>
    <child link="link1"/>
  </joint>
  <joint name="joint_box" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0.8"/>
    <parent link="link1"/>
    <child link="link_box"/>
  </joint>
</robot>
