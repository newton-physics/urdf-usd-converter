<robot name="error_incorrect_mimic_joint_fixed">
  <link name="BaseLink">
    <visual>
      <origin rpy="0 0 0" xyz="-2 0 0.5"/>
      <geometry>
        <box size="1 1 1"/>
      </geometry>
    </visual>
  </link>

  <link name="link2">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.5"/>
      <geometry>
        <sphere radius="0.5"/>
      </geometry>
    </visual>
  </link>
  <link name="link3">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.5"/>
      <geometry>
        <sphere radius="0.5"/>
      </geometry>
    </visual>
  </link>
  <link name="link4">
    <visual>
      <origin rpy="0 0 0" xyz="-1 0 0.5"/>
      <geometry>
        <sphere radius="0.5"/>
      </geometry>
    </visual>
  </link>

  <joint name="JointA" type="fixed">
    <parent link="BaseLink"/>
    <child link="link2" />
  </joint>
  <joint name="JointB" type="fixed">
    <parent link="BaseLink"/>
    <child link="link4" />
  </joint>

  <joint name="JointC" type="fixed">
    <parent link="link2"/>
    <child link="link3" />

    <!-- This is a deliberate mistake.  -->
    <!-- When referring to a fixed joint. -->
    <mimic joint="JointB" multiplier="2.0" offset="1.0"/>
  </joint>
</robot>
